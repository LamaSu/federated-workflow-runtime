{
  "name": "@delightfulchorus/integration-workflow",
  "version": "0.1.9",
  "description": "Subgraph composition — invoke another local Chorus workflow as a single memoized step. Recursive: child workflows can themselves contain subgraph nodes.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "chorus",
    "chorus-integration",
    "workflow",
    "subgraph",
    "composition",
    "supervisor",
    "hierarchical",
    "integration",
    "n8n-alternative"
  ],
  "author": "Chorus contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/LamaSu/federated-workflow-runtime.git",
    "directory": "integrations/workflow"
  },
  "bugs": {
    "url": "https://github.com/LamaSu/federated-workflow-runtime/issues"
  },
  "homepage": "https://github.com/LamaSu/federated-workflow-runtime#readme",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/",
    "provenance": true
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "test": "vitest run",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "@delightfulchorus/core": "*",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@delightfulchorus/fbp": "*"
  }
}
