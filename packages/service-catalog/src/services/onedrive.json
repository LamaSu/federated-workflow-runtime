{
  "serviceId": "onedrive",
  "displayName": "OneDrive (Microsoft Graph)",
  "docsUrl": "https://learn.microsoft.com/en-us/onedrive/developer/rest-api/",
  "baseUrl": "https://graph.microsoft.com",
  "authTypes": [
    {
      "id": "onedriveOAuth",
      "displayName": "Microsoft Identity OAuth 2.0",
      "authType": "oauth2",
      "fields": [
        {
          "name": "accessToken",
          "displayName": "Access Token",
          "type": "password",
          "required": true,
          "oauthManaged": true
        },
        {
          "name": "refreshToken",
          "displayName": "Refresh Token",
          "type": "password",
          "required": false,
          "oauthManaged": true
        }
      ],
      "authHeader": {
        "name": "Authorization",
        "format": "Bearer {accessToken}"
      },
      "oauth": {
        "authorizeUrl": "https://login.microsoftonline.com/common/oauth2/v2.0/authorize",
        "tokenUrl": "https://login.microsoftonline.com/common/oauth2/v2.0/token",
        "scopes": ["Files.ReadWrite", "offline_access"],
        "pkce": true,
        "clientAuthStyle": "body",
        "redirectPath": "/oauth/callback",
        "authorizeQueryParams": {}
      },
      "documentationUrl": "https://learn.microsoft.com/en-us/graph/auth/"
    }
  ],
  "commonOperations": [
    {
      "id": "get-me",
      "displayName": "Get Current User",
      "method": "GET",
      "path": "/v1.0/me",
      "description": "Retrieve the signed-in user."
    },
    {
      "id": "list-children",
      "displayName": "List Drive Root Children",
      "method": "GET",
      "path": "/v1.0/me/drive/root/children",
      "description": "List files in the user's root folder."
    },
    {
      "id": "get-item",
      "displayName": "Get Drive Item",
      "method": "GET",
      "path": "/v1.0/me/drive/items/{item_id}",
      "description": "Get metadata for a single drive item."
    },
    {
      "id": "upload-small-file",
      "displayName": "Upload Small File (< 4MB)",
      "method": "PUT",
      "path": "/v1.0/me/drive/root:/{filename}:/content",
      "description": "Upload a small file (direct PUT). For larger files, use createUploadSession."
    }
  ]
}
