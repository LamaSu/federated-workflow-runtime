{
  "serviceId": "google-calendar",
  "displayName": "Google Calendar",
  "docsUrl": "https://developers.google.com/calendar/api/v3/reference",
  "baseUrl": "https://www.googleapis.com",
  "authTypes": [
    {
      "id": "googleCalendarOAuth",
      "displayName": "Google OAuth 2.0",
      "authType": "oauth2",
      "fields": [
        {
          "name": "accessToken",
          "displayName": "Access Token",
          "type": "password",
          "required": true,
          "oauthManaged": true
        },
        {
          "name": "refreshToken",
          "displayName": "Refresh Token",
          "type": "password",
          "required": false,
          "oauthManaged": true
        }
      ],
      "authHeader": {
        "name": "Authorization",
        "format": "Bearer {accessToken}"
      },
      "oauth": {
        "authorizeUrl": "https://accounts.google.com/o/oauth2/v2/auth",
        "tokenUrl": "https://oauth2.googleapis.com/token",
        "scopes": ["https://www.googleapis.com/auth/calendar"],
        "pkce": true,
        "clientAuthStyle": "body",
        "redirectPath": "/oauth/callback",
        "authorizeQueryParams": {
          "access_type": "offline",
          "prompt": "consent"
        }
      },
      "documentationUrl": "https://developers.google.com/calendar/api/guides/auth"
    }
  ],
  "commonOperations": [
    {
      "id": "list-calendars",
      "displayName": "List Calendars",
      "method": "GET",
      "path": "/calendar/v3/users/me/calendarList",
      "description": "List calendars on the user's list."
    },
    {
      "id": "list-events",
      "displayName": "List Events",
      "method": "GET",
      "path": "/calendar/v3/calendars/{calendarId}/events",
      "description": "List events in a calendar. Use calendarId='primary' for the user's main calendar."
    },
    {
      "id": "create-event",
      "displayName": "Create Event",
      "method": "POST",
      "path": "/calendar/v3/calendars/{calendarId}/events",
      "description": "Create a new event.",
      "bodyContentType": "application/json",
      "inputSchema": {
        "type": "object",
        "required": ["start", "end"],
        "properties": {
          "summary": { "type": "string" },
          "start": { "type": "object" },
          "end": { "type": "object" },
          "attendees": { "type": "array" }
        }
      }
    },
    {
      "id": "delete-event",
      "displayName": "Delete Event",
      "method": "DELETE",
      "path": "/calendar/v3/calendars/{calendarId}/events/{eventId}",
      "description": "Delete an event."
    }
  ]
}
