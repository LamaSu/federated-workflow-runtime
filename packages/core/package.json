{
  "name": "@delightfulchorus/core",
  "version": "0.1.5",
  "description": "Shared types, schemas, and utilities for Chorus",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./schemas": {
      "import": "./dist/schemas.js",
      "types": "./dist/schemas.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "chorus",
    "workflow",
    "automation",
    "zod",
    "schemas",
    "types",
    "n8n-alternative"
  ],
  "author": "Chorus contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/LamaSu/federated-workflow-runtime.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/LamaSu/federated-workflow-runtime/issues"
  },
  "homepage": "https://github.com/LamaSu/federated-workflow-runtime#readme",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsup src/index.ts src/schemas.ts --format esm --dts --clean",
    "test": "vitest run",
    "dev": "tsup src/index.ts src/schemas.ts --format esm --dts --watch",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "zod": "^3.23.0"
  }
}
