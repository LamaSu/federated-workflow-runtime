{
  "name": "@delightfulchorus/cli",
  "version": "0.1.8",
  "description": "Chorus CLI — chorus init, chorus run, chorus report",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "chorus": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "chorus",
    "workflow",
    "cli",
    "automation",
    "npx",
    "scaffold",
    "runtime",
    "agent",
    "n8n-alternative"
  ],
  "author": "Chorus contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/LamaSu/federated-workflow-runtime.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/LamaSu/federated-workflow-runtime/issues"
  },
  "homepage": "https://github.com/LamaSu/federated-workflow-runtime#readme",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/",
    "provenance": true
  },
  "scripts": {
    "build": "tsup src/cli.ts --format esm --dts --clean --external @delightfulchorus/core --external @delightfulchorus/registry --external @delightfulchorus/reporter --external @delightfulchorus/repair-agent --external @delightfulchorus/runtime --external @delightfulchorus/mcp",
    "test": "vitest run",
    "cli": "tsx src/cli.ts",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "@delightfulchorus/core": "*",
    "@delightfulchorus/mcp": "*",
    "@delightfulchorus/registry": "*",
    "@delightfulchorus/reporter": "*",
    "@delightfulchorus/repair-agent": "*",
    "@delightfulchorus/runtime": "*",
    "commander": "^12.1.0",
    "picocolors": "^1.1.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "tsx": "^4.19.0"
  }
}
